<script>
(function() {
	// Données des providers
	const providers = <?= json_encode($providers, JSON_UNESCAPED_UNICODE) ?>;
	const defaultPrompt = <?= json_encode($defaultPrompt) ?>;

	// Provider selection
	document.querySelectorAll('input[name="ai_provider"]').forEach(radio => {
		radio.addEventListener('change', function() {
			const p = providers[this.value];
			document.getElementById('field-api-key').style.display = p.needs_key ? '' : 'none';
			document.getElementById('field-api-url').style.display = p.needs_url ? '' : 'none';

			// Update model select
			const select = document.getElementById('ai_model_select');
			const currentVal = document.getElementById('ai_model').value;
			select.innerHTML = '';
			p.models.forEach(m => {
				const opt = document.createElement('option');
				opt.value = m;
				opt.textContent = m;
				if (m === currentVal) opt.selected = true;
				select.appendChild(opt);
			});
			const customOpt = document.createElement('option');
			customOpt.value = '__custom__';
			customOpt.textContent = '✏️ Saisir un modèle personnalisé...';
			select.appendChild(customOpt);

			// Update provider card style
			document.querySelectorAll('.adc-provider-card').forEach(card => {
				card.classList.remove('selected');
			});
			this.closest('.adc-provider-card').classList.add('selected');
		});
	});

	// Model select/input toggle
	const modelSelect = document.getElementById('ai_model_select');
	const modelInput = document.getElementById('ai_model');

	modelSelect.addEventListener('change', function() {
		if (this.value === '__custom__') {
			this.style.display = 'none';
			modelInput.style.display = '';
			modelInput.focus();
		} else {
			modelInput.value = this.value;
		}
	});

	modelInput.addEventListener('blur', function() {
		if (this.value) {
			modelSelect.style.display = '';
			this.style.display = 'none';
		}
	});

	// Initialize model value from select
	if (modelSelect.value !== '__custom__') {
		modelInput.value = modelSelect.value;
	}

	// Range sliders live feedback
	const ranges = [
		{ id: 'ai_temperature', badge: 'temp-badge', format: v => parseFloat(v).toFixed(1) },
		{ id: 'ai_max_articles', badge: 'articles-badge', format: v => v },
		{ id: 'ai_max_chars', badge: 'chars-badge', format: v => v },
	];
	ranges.forEach(({ id, badge, format }) => {
		const input = document.getElementById(id);
		const badgeEl = document.getElementById(badge);
		if (input && badgeEl) {
			input.addEventListener('input', () => badgeEl.textContent = format(input.value));
		}
	});

	// Password toggle
	document.querySelectorAll('.adc-toggle-password').forEach(btn => {
		btn.addEventListener('click', function() {
			const input = this.previousElementSibling;
			input.type = input.type === 'password' ? 'text' : 'password';
		});
	});

	// Email toggle
	const emailToggle = document.getElementById('email_enabled');
	const emailSettings = document.getElementById('email-settings');
	emailToggle.addEventListener('change', function() {
		emailSettings.style.display = this.checked ? '' : 'none';
	});

	// Reset prompt
	document.getElementById('reset-prompt').addEventListener('click', function() {
		if (confirm('Réinitialiser le prompt par défaut ?')) {
			document.getElementById('ai_prompt').value = defaultPrompt;
		}
	});

	// Test email
	document.getElementById('test-email-btn').addEventListener('click', async function() {
		const status = document.getElementById('test-email-status');
		this.disabled = true;
		status.textContent = '⏳ Envoi en cours...';
		status.className = 'adc-inline-status';

		try {
			const resp = await fetch('?aiDigestAction=emailReport&get=a');
			const data = await resp.json();
			if (data.success) {
				status.textContent = '✅ ' + (data.message || 'Email envoyé !');
				status.className = 'adc-inline-status success';
			} else {
				status.textContent = '❌ ' + (data.error || 'Erreur');
				status.className = 'adc-inline-status error';
			}
		} catch (e) {
			status.textContent = '❌ Erreur réseau';
			status.className = 'adc-inline-status error';
		}
		this.disabled = false;
	});
})();
</script>
