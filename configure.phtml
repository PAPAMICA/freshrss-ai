<script>
(function() {
	var providers = <?= json_encode(array_map(fn($p) => ['url' => $p['url'], 'models' => $p['models'], 'needs_key' => $p['needs_key'], 'needs_url' => $p['needs_url']], $providers), JSON_UNESCAPED_UNICODE) ?>;
	var defaultPrompt = <?= json_encode($defaultPrompt) ?>;

	// ─── Provider selection ─────────────────────────────────────────
	document.querySelectorAll('input[name="ai_provider"]').forEach(function(radio) {
		radio.addEventListener('change', function() {
			var p = providers[this.value];

			// Key field
			document.getElementById('field-api-key').style.display = p.needs_key ? '' : 'none';

			// URL field - always visible, but readonly for known providers
			var urlInput = document.getElementById('ai_api_base_url');
			urlInput.readOnly = !p.needs_url;
			if (p.url) urlInput.value = p.url;
			else if (p.needs_url) urlInput.value = '';

			// Update model select
			var select = document.getElementById('ai_model_select');
			var currentVal = document.getElementById('ai_model').value;
			select.innerHTML = '';
			p.models.forEach(function(m) {
				var opt = document.createElement('option');
				opt.value = m; opt.textContent = m;
				if (m === currentVal) opt.selected = true;
				select.appendChild(opt);
			});
			// Custom option
			var custom = document.createElement('option');
			custom.value = '__custom__';
			custom.textContent = '-- Saisir un modèle --';
			select.appendChild(custom);

			// If model not in list, show input
			if (p.models.length > 0 && !p.models.includes(currentVal)) {
				document.getElementById('ai_model').value = p.models[0];
				select.options[0].selected = true;
			}

			// Provider card active state
			document.querySelectorAll('.adc-provider-card').forEach(function(card) {
				card.classList.remove('selected');
			});
			this.closest('.adc-provider-card').classList.add('selected');
		});
	});

	// ─── Model select ───────────────────────────────────────────────
	var modelSelect = document.getElementById('ai_model_select');
	var modelInput  = document.getElementById('ai_model');

	// Keep hidden input in sync
	modelSelect.addEventListener('change', function() {
		if (this.value === '__custom__') {
			this.style.display = 'none';
			modelInput.style.display = '';
			modelInput.focus();
		} else {
			modelInput.value = this.value;
		}
	});
	modelInput.addEventListener('keydown', function(e) {
		if (e.key === 'Enter') { e.preventDefault(); this.blur(); }
	});
	modelInput.addEventListener('blur', function() {
		if (this.value) {
			// Check if value is in select options
			var found = false;
			for (var i = 0; i < modelSelect.options.length; i++) {
				if (modelSelect.options[i].value === this.value) { found = true; break; }
			}
			if (found || modelSelect.options.length <= 1) {
				modelSelect.style.display = '';
				this.style.display = 'none';
			}
		}
	});
	// Init
	if (modelSelect.value !== '__custom__') modelInput.value = modelSelect.value;

	// ─── Sliders live feedback ──────────────────────────────────────
	[
		['ai_temperature',  'temp-badge',     function(v) { return parseFloat(v).toFixed(1) }],
		['ai_max_articles', 'articles-badge', function(v) { return v }],
		['ai_max_chars',    'chars-badge',    function(v) { return v }],
	].forEach(function(r) {
		var input = document.getElementById(r[0]);
		var badge = document.getElementById(r[1]);
		if (input && badge) input.addEventListener('input', function() { badge.textContent = r[2](this.value) });
	});

	// ─── Password toggle ────────────────────────────────────────────
	document.getElementById('toggle-pwd').addEventListener('click', function() {
		var inp = document.getElementById('ai_api_key');
		inp.type = inp.type === 'password' ? 'text' : 'password';
	});

	// ─── Email toggle ────────────────────────────────────────────────
	document.getElementById('email_enabled').addEventListener('change', function() {
		document.getElementById('email-settings').style.display = this.checked ? '' : 'none';
	});

	// ─── Reset prompt ────────────────────────────────────────────────
	document.getElementById('reset-prompt').addEventListener('click', function() {
		if (confirm('Réinitialiser le prompt par défaut ?')) {
			document.getElementById('ai_prompt').value = defaultPrompt;
		}
	});

	// ─── Test API connection ─────────────────────────────────────────
	document.getElementById('test-api-btn').addEventListener('click', async function() {
		var resultBox = document.getElementById('test-api-result');
		this.disabled = true;
		resultBox.style.display = '';
		resultBox.className = 'adc-test-result';
		resultBox.textContent = 'Test en cours…';

		try {
			var resp = await fetch('?aiDigestAction=testConnection');
			var data = await resp.json();
			if (data.success) {
				resultBox.className = 'adc-test-result success';
				resultBox.textContent = data.message;
			} else {
				resultBox.className = 'adc-test-result error';
				resultBox.textContent = data.error || 'Erreur inconnue';
			}
		} catch(e) {
			resultBox.className = 'adc-test-result error';
			resultBox.textContent = 'Erreur réseau : ' + e.message;
		}
		this.disabled = false;
	});

	// ─── Test email ──────────────────────────────────────────────────
	document.getElementById('test-email-btn').addEventListener('click', async function() {
		var status = document.getElementById('test-email-status');
		this.disabled = true;
		status.textContent = 'Envoi…';
		status.className = 'adc-inline-status';

		try {
			var resp = await fetch('?aiDigestAction=emailReport&get=a');
			var data = await resp.json();
			if (data.success) {
				status.textContent = data.message || 'Email envoyé !';
				status.className = 'adc-inline-status success';
			} else {
				status.textContent = data.error || 'Erreur';
				status.className = 'adc-inline-status error';
			}
		} catch(e) {
			status.textContent = 'Erreur réseau';
			status.className = 'adc-inline-status error';
		}
		this.disabled = false;
	});
})();
</script>
